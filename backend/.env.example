# ---- Narcos Tacos POS — Environment Variables ----
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# Postgres connection string
DATABASE_URL=postgresql://narcos:narcos_dev@localhost:5432/narcos_tacos

# Server port
PORT=4000

# Signs the Back Office session cookie (JWT) and the "awaiting 2FA"/"2FA
# setup" temp tokens. Any long random string — generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Signs the device-pairing cookie (JWT) that marks an Order Entry/KDS
# device as paired. Deliberately a SEPARATE secret from SESSION_SECRET —
# device trust and staff session trust are orthogonal layers, so a leak
# of one shouldn't compromise the other. Generate the same way:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
DEVICE_SECRET=

# Resend API key (transactional email — Back Office forgot-password links).
# narcostacos.ca is already verified with Resend; do not hardcode this key
# or log it anywhere.
RESEND_API_KEY=

# Base URL of the frontend, used to build the reset-password link emailed
# to owners/admins. No trailing slash.
FRONTEND_URL=http://localhost:5173
